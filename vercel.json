{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/api/scrape", "destination": "/api/scrape" }
  ],
  "crons": [
    {
      "path": "/api/scrape",
      "schedule": "0 10 * * *"
    }
  ],
  "functions": {
    "api/scrape.js": {
      "maxDuration": 60
    }
  }
}
